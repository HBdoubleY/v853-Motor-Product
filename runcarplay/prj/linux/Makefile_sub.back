SDKDEBUG_FLAGS = -O3
MAKEDEPEND = $(CC) -MM -MT

CFLAGS = $(SDKDEBUG_FLAGS) -Wall -W
CPPFLAGS = $(SDKDEBUG_FLAGS) -Wall -W

CFLAGS :=   -Wall -O3 -g0 -pipe -fpermissive -Wno-unused-local-typedefs \
	   	-march=armv7-a -mtune=cortex-a7 -mfpu=neon -mfloat-abi=hard -fno-caller-saves -Wno-unused-result -Wformat -Werror=format-security -fstack-protector -Wl,-z,now -Wl,-z,relro -ffunction-sections -fdata-sections   \
		 -D_LARGEFILE_SOURCE -D_LARGEFILE64_SOURCE -D_FILE_OFFSET_BITS=64 -D__STDC_CONSTANT_MACROS \
		-D_GNU_SOURCE -D_REENTRANT \
		 $(CFLAGS)

CPPFLAGS := -Wall -O3 -g0 -pipe -fpermissive -Wno-unused-local-typedefs \
	   	-march=armv7-a -mtune=cortex-a7 -mfpu=neon -mfloat-abi=hard -fno-caller-saves -Wno-unused-result -Wformat -Werror=format-security -fstack-protector -Wl,-z,now -Wl,-z,relro -ffunction-sections -fdata-sections   \
		 -D_LARGEFILE_SOURCE -D_LARGEFILE64_SOURCE -D_FILE_OFFSET_BITS=64 -D__STDC_CONSTANT_MACROS \
		-D_GNU_SOURCE -D_REENTRANT \
		 $(CPPFLAGS)


