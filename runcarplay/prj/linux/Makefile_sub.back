MAKE = make

CEDAR_INC += $(USER_INCS)

#��ý�徲̬��Ŀ¼
mpp_lib_dir=$(USRLIB_PATH)/aw_pack_src/lib_aw/lib/eyesee-mpp
mpp_lib_dir += $(USRLIB_PATH)/aw_pack_src/lib_aw/lib/libawaiisp
user_lib_dir = $(addprefix -L ,  $(shell find $(mpp_lib_dir) -type d))
LINKFLAGS = \
	-lpthread -lrt -ldl -lm -Wl,--gc-sections \
	$(user_lib_dir) \

#�Զ������ӿ��ļ����������е�.a��
#�������е�.a���ļ�
lib_files := $(foreach dir,$(mpp_lib_dir),$(wildcard $(dir)/*.a))
#���ļ�ȥ��Ŀ¼��ֻ�����ļ���
lib_nordir :=  $(notdir $(lib_files))
#���������ȥ��ͷlib �� β��.a
lib_name := $(patsubst lib%,%,$(patsubst %.a,%,$(lib_nordir)))
#�����п�����-l����
ld_mpp_libs := $(addprefix -l, $(lib_name))

LIBSA +=  -ldl -lrt -lpthread -lm -lc -lz  -fPIC -Wall -Wno-unused-but-set-variable \
     	-Wl,--start-group   \
-L../../../external/lib      \
-L../../../external/aw_pack_src/lib_aw/lib/eyesee-mpp	\
-L../../../external/aw_pack_src/lib_aw/lib/libawaiisp	\
-L../../../external/carplay/libzbt	\
-L../../../external/carplay/lib	\
-lvideoengine -laacenc -lcdx_mp3_parser -ladecoder -lthumbretriever \
-lexpat -lcamera -lhwdisplay -lisp_dev -lcustomaw_media_utils \
-lisp_afs -lcdx_base -lisp_gtm -lcdx_mpg_parser -lisp_base \
-lwav_muxer -lvencoder -lrecorder -lcedarx_aencoder -lcdx_file_stream \
-law_mpp -lisp_pltm -lvenc_base -lvenc_h264 -lplayer -lcedarxstream -lisp_awb \
-lcivetweb -lmedia_utils -liniparser -lraw_muxer -lIniParserMpp \
-lcdx_flac_parser -lcedarx_tencoder -lAudioVps -llz4 -lmpeg2ts_muxer \
-lcdx_mov_parser -lcedarxdemuxer -lawion -lResample -laac_muxer \
-lfreetype -lVE -lfilerepair -lisp_ini -lisp_af -lmuxers -lffavutil \
-lcdx_wav_parser -lAns -lawmjpeg -lcdx_parser \
-lsample_confparser -lMemAdapter -lSQLiteCpp -lcdx_ape_parser \
-lisp_math -lawh265 -lawh264 -lmp3_muxer -lcedarxrender -lPluginMpp \
-lISP -lvenc_jpeg -lisp_ae -lcdx_ts_parser -lvdecoder \
-lwav -lluaconfig -lmp4_muxer -lcdx_aac_parser -laac -lAec -lisp_md \
-lTinyServer -lvenc_common -lcdc_base -lcdx_ogg_parser -lvenc_h265 \
-lisp_iso -lz -lmotion -lglog -llog -lcdx_stream -lFsWriter -lAgc \
-lcdx_id3v2_parser -lcdx_amr_parser -lisp_rolloff -lawaiisp \
