    	-Wl,--end-group

# -lrgb_ctrl 

LDFLAGS = -Wl,-gc-sections	


FILDIRS := ./depend% ./obj% $(SRCDIR)/arch/win $(SRCDIR)/drivers/win

SRCDIRS = $(filter-out $(FILDIRS),$(shell find $(SRCDIR) -maxdepth 3 -type d))


#==================��������SRC_PATHĿ¼c��c++Դ��·��=============#	
CSRCS =  $(foreach dir,$(SRCDIRS),$(wildcard $(dir)/*.c))  
CPPSRCS = $(foreach dir,$(SRCDIRS),$(wildcard $(dir)/*.cpp))

#=================��������obj·������������================#
OBJROOTDIR = ./obj
COBJS =    $(subst $(SRCDIR),$(OBJROOTDIR),$(CSRCS:.c=.o))
CPPOBJS =  $(subst $(SRCDIR),$(OBJROOTDIR),$(CPPSRCS:.cpp=.o))


#================�������ÿ��.c�ļ���.d��������=============#
DEFROOTDIR = ./depend
CDEF = $(subst $(SRCDIR),$(DEFROOTDIR),$(CSRCS:.c=.d))
CPPDEF = $(subst $(SRCDIR),$(DEFROOTDIR),$(CPPSRCS:.cpp=.d)) 


all:$(BIN)
	@echo "\n$(BIN) compile ok!!!\n\n"


$(CDEF) :$(DEFROOTDIR)%.d :$(SRCDIR)%.c
	set -e; rm -f $@; \
	$(MAKEDEPEND) $(<:.c=.o) $< $(CEDAR_INC) $(CEDAR_MACORS) $(SRCINC) > $@.$$$$; \
	sed 's,$(<:.c=.o),obj/$(<:.c=.o) $@ ,g' < $@.$$$$ > $@; \
	rm -f $@.$$$$

$(CPPDEF) : $(DEFROOTDIR)%.d :$(SRCDIR)%.cpp
	set -e; rm -f $@; \
	$(MAKEDEPEND) $(<:.cpp=.o) $< $(CEDAR_INC) $(CEDAR_MACORS) $(SRCINC) > $@.$$$$; \
	sed 's,$(<:.cpp=.o),obj/$(<:.cpp=.o) $@ ,g' < $@.$$$$ > $@; \
	rm -f $@.$$$$

depend:
	rm -f $(CDEF)
	rm -f $(CPPDEF)
	$(MAKE) $(CDEF)
	$(MAKE) $(CPPDEF)

$(COBJS) : $(OBJROOTDIR)%.o:$(SRCDIR)%.c 
	$(CC) -c $< -o $@  $(CFLAGS) $(CEDAR_INC) $(CEDAR_MACORS) $(SRCINC)
$(CPPOBJS) : $(OBJROOTDIR)%.o:$(SRCDIR)%.cpp
	$(CPP) -c $< -o $@  $(CPPFLAGS) $(CEDAR_INC) $(CEDAR_MACORS) $(SRCINC)

$(BIN) : $(COBJS) $(CPPOBJS)
	$(CPP) -o $(BIN) $(COBJS) $(CPPOBJS) $(LIBS) $(LIBSA) $(LDFLAGS) $(LINKFLAGS)
	$(STRIP) $(BIN)


-include $(CDEF)
-include $(CPPDEF)
.PHONY:clean cleanall distclean

clean:            
	@rm -f $(BIN) $(COBJS) $(CPPOBJS)

cleanall:
	@rm -f $(CDEF) $(CPPDEF)
	@rm -f $(BIN) $(COBJS) $(CPPOBJS)
	@rm -rf depend
	@rm -rf obj
