#!/bin/sh

killall runcarplay
if [ $? -eq 0 ]
then
	sleep 1
	exit
fi

echo 1 > /sys/class/gpio_sw/PE8/cfg
echo 0 > /sys/class/gpio_sw/PE8/data

chmod 777 /dev/input/event0

#echo 4 > /proc/sys/kernel/printk

mkdir -p /var/run
mkdir -p /var/lib
mkdir -p /var/lib/misc
mkdir -p /var/run/hostapd

ln -s /usr/sbin/mdnsd  /var/run/mdnsd 2>/dev/null || true

# 按 libzlink 文档：无线 CarPlay/AA 连接前需先配置 wlan0 为 AP，再启动 zlink，否则无法握手
ifconfig lo up
killall wpa_supplicant 2>/dev/null || true
killall udhcpc 2>/dev/null || true
killall hostapd 2>/dev/null || true
killall udhcpd 2>/dev/null || true
sleep 1
ifconfig wlan0 up
ifconfig wlan0 192.168.1.2 netmask 255.255.255.0
# 使用开发板 /etc 下的 hostapd.conf、udhcpd.conf（需事先放到板子 /etc/ 目录）
if [ -f /etc/hostapd.conf ]; then
	hostapd -B /etc/hostapd.conf &
	sleep 1
fi
if [ -f /etc/udhcpd.conf ]; then
	touch /var/lib/misc/udhcpd.leases
	udhcpd -f /etc/udhcpd.conf wlan0 &
fi

# wlan1 = STA，用于 WiFi 联网（扫描/连接路由器），与 wlan0 CarPlay AP 并存
ifconfig wlan1 up 2>/dev/null || true
mkdir -p /var/run/wpa_supplicant
if [ ! -f /tmp/wpa_wlan1.conf ]; then
	echo "ctrl_interface=/var/run/wpa_supplicant" > /tmp/wpa_wlan1.conf
	echo "update_config=1" >> /tmp/wpa_wlan1.conf
	echo "ap_scan=1" >> /tmp/wpa_wlan1.conf
	echo "fast_reauth=1" >> /tmp/wpa_wlan1.conf
	echo "country=CN" >> /tmp/wpa_wlan1.conf
fi
wpa_supplicant -B -i wlan1 -D nl80211 -c /tmp/wpa_wlan1.conf >/dev/null 2>&1 || \
	wpa_supplicant -B -i wlan1 -D wext -c /tmp/wpa_wlan1.conf >/dev/null 2>&1 || true

if [ ! -d "/opt/work/data_car" ];then
  mkdir /opt/work/data_car
fi

if [ ! -d "/dev/shm" ];then
  mkdir /dev/shm
fi


export PATH=$PATH:/opt/work/app/carplay/lib
export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/opt/work/app/carplay/lib

export PATH=$PATH:/opt/work/app/carplay/carplaylib
export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/opt/work/app/carplay/carplaylib

#echo 0 > /dev/watchdog

echo 1 > /sys/class/gpio_sw/PE8/data


/opt/work/app/carplay/gocsdk &
/opt/work/app/carplay/carplaylib/zlink.sh &

cd /opt/work/app/carplay
echo "-------------run------------"

#source ./qtenv.rc
rm -f /tmp/disable_reboot.flag

./SDUpgrade &
./runcarplay

# 检查标志文件
if [ -f "/tmp/disable_reboot.flag" ]; then
    echo "------------- SDUpgrade requested no reboot -------------------"
    rm -f /tmp/disable_reboot.flag

else
	echo "-------------exit err, -------------------"
	sleep 3
	reboot
	reboot
fi